{
	"name": "stimulsp",
	"description": "A simple stimulus lsp",
	"author": "Antonis Gkamitsios",
	"license": "MIT",
	"version": "1.1.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/antonisgkamitsios/stimulus-lsp"
	},
	"publisher": "antonisgkamitsios",
	"categories": [],
	"keywords": [
		"multi-root ready"
	],
	"engines": {
		"vscode": "^1.100.0"
	},
	"activationEvents": [
		"onStartupFinished",
		"onLanguage:html"
	],
	"main": "./client/out/extension",
	"contributes": {
		"configuration": {
			"type": "object",
			"title": "Stimulus LSP configuration",
			"properties": {
				"stimulsp.controllersDirs": {
					"scope": "resource",
					"type": "array",
					"default": [
						"./app/controllers"
					],
					"description": "Paths to your Stimulus controllers directory"
				},
				"stimulsp.activationLanguages": {
					"scope": "window",
					"type": "array",
					"default": [
						"html"
					],
					"description": "Languages that Stimulus LSP will activate on.",
					"restartRequired": true
				},
				"stimulsp.fileWatchPattern": {
					"scope": "resource",
					"type": "string",
					"default": "**/*_controller.{ts,js}",
					"description": "Glob pattern for files to watch for controller changes"
				}
			}
		},
		"htmlLanguageParticipants": [
			{
				"languageId": "html",
				"autoInsert": true
			}
		]
	},
	"workspaces": [
		"client",
		"server",
		"shared"
	],
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "npm run compile --workspace=shared && npm run compile --workspace=client && npm run compile --workspace=server",
		"watch": "tsc -b -w",
		"lint": "eslint",
		"test": "sh ./scripts/e2e.sh"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/mocha": "^10.0.6",
		"@types/node": "^22",
		"esbuild": "^0.27.4",
		"eslint": "^9.13.0",
		"mocha": "^10.3.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	}
}

{
	"name": "stimulus-lsp",
	"description": "A simple stimulus lsp",
	"author": "Antonis Gkamitsios",
	"license": "MIT",
	"version": "1.0.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/antonisgkamitsios/stimulus-lsp"
	},
	"publisher": "vscode-samples",
	"categories": [],
	"keywords": [
		"multi-root ready"
	],
	"engines": {
		"vscode": "^1.100.0"
	},
	"activationEvents": [
		"onStartupFinished",
		"onLanguage:html"
	],
	"main": "./client/out/extension",
	"contributes": {
		"configuration": {
			"type": "object",
			"title": "Stimulus LSP configuration",
			"properties": {
				"stimulus.controllersDirs": {
					"scope": "resource",
					"type": "array",
					"default": [
						"./app/controllers"
					],
					"description": "Paths to your Stimulus controllers directory"
				},
				"stimulus.fileWatchPattern": {
					"scope": "resource",
					"type": "string",
					"default": "**/*_controller.{ts,js}",
					"description": "Glob pattern for files to watch for controller changes"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -b",
		"watch": "tsc -b -w",
		"lint": "eslint",
		"postinstall": "cd client && npm install && cd ../server && npm install && cd ..",
		"test": "sh ./scripts/e2e.sh"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/mocha": "^10.0.6",
		"@types/node": "^22",
		"eslint": "^9.13.0",
		"mocha": "^10.3.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	}
}